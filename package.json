{
  "name": "environment-health-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs src",
    "lint:arch:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot src | dot -T svg -o docs/dependency-graph.svg"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
